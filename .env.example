# Yapay Zeka Destekli Almanca Öğrenme Projesi - Environment Variables
# Developer: Betül Altınkaynak Demirel

# Google Gemini API Key (Gemini 2.5 Flash / 2.0 Flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (LLaMA 3.3 70B)
GROQ_API_KEY=your_groq_api_key_here

# Preferred AI Provider: "gemini" or "groq"
DEFAULT_AI_PROVIDER=gemini

# Database Settings
DATABASE_URL=sqlite:///./data/german_ai.db

# App Settings
PORT=8000
HOST=0.0.0.0
